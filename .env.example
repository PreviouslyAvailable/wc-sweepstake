# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Steward passcode — gates draw desk, results desk, and all write API routes
ADMIN_PASSCODE=

# Vercel cron auth — set automatically on Vercel; use locally when testing /api/sync
CRON_SECRET=

# Primary results feed (free, no key) — set to true to disable
# WORLDCUP26_DISABLED=true
# WORLDCUP26_API_URL=https://worldcup26.ir

# Optional API-Football card counts — set API_FOOTBALL_ENABLED=true + API_FOOTBALL_KEY (Pro plan for WC 2026)
# API_FOOTBALL_ENABLED=true
# API_FOOTBALL_KEY=

# Optional SportAPI fallback (RapidAPI) — used when worldcup26 is disabled
# SPORTAPI_ENABLED=true
# RAPIDAPI_KEY=
# SPORTAPI_WC_TOURNAMENT_ID=16
# SPORTAPI_WC_SEASON_ID=58210
# SPORTAPI_WORLD_CATEGORY_ID=1468
# SPORTAPI_TOURNAMENT_KEYWORD=World Cup
